{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["svelte"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,
    "skipLibCheck": true
