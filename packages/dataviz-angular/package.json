{
  "name": "@sentropic/dataviz-angular",
  "version": "0.4.52",
  "description": "Angular adapter for @sentropic/dataviz-core, built on @sentropic/design-system-angular.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rhanka/dataviz.git",
    "directory": "packages/dataviz-angular"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "sideEffects": false,
  "scripts": {
    "build": "npm run build -w @sentropic/dataviz-core && ngc -p tsconfig.lib.json",
    "check": "npm run build -w @sentropic/dataviz-core && ngc -p tsconfig.lib.json --noEmit",
    "test": "npm run build && vitest run --config vitest.config.ts src"
  },
  "dependencies": {
    "@sentropic/dataviz-core": "0.4.52",
    "@sentropic/design-system-angular": "file:../../vendor/sentropic-design-system-angular-0.36.51.tgz",
    "@sentropic/design-system-themes": "0.11.0"
  },
  "peerDependencies": {
    "@angular/core": "^20.0.0 || ^21.0.0 || ^22.0.0"
  },
  "devDependencies": {
    "@angular/compiler": "^21.2.17",
    "@angular/compiler-cli": "^21.2.17",
    "@angular/core": "^21.2.17",
    "@angular/platform-browser": "^21.2.17",
    "@angular/platform-browser-dynamic": "^21.2.17",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.6"
  }
}
