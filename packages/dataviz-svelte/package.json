{
  "name": "@sentropic/dataviz-svelte",
  "version": "0.4.48",
  "description": "Svelte 5 adapter + dashboard components for @sentropic/dataviz-core, built on @sentropic/design-system-svelte.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rhanka/dataviz.git",
    "directory": "packages/dataviz-svelte"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "svelte": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "svelte-package --input src && rm -f dist/*.test.* dist/lib/*.test.*",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run src"
  },
  "dependencies": {
    "@sentropic/dataviz-core": "0.4.48",
    "@sentropic/design-system-svelte": "0.34.45",
    "@sentropic/design-system-themes": "0.11.0",
    "jspdf": "^4.2.1",
    "svg2pdf.js": "^2.7.0"
  },
  "peerDependencies": {
    "svelte": "^5"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/svelte": "^5.3.1",
    "svelte": "^5.56.2",
    "svelte-check": "^4.0.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
